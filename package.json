{
  "name": "subscription-calculator-obsidian",
  "version": "0.9.2",
  "description": "Obsidian plugin for local subscription tracking.",
  "private": true,
  "license": "MIT",
  "main": "main.js",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "dev:reload": "node esbuild.config.mjs --watch-reload",
    "build": "tsc --noEmit --skipLibCheck && node esbuild.config.mjs production",
    "build:reload": "npm run build && node esbuild.config.mjs --reload-only",
    "test": "tsc --noEmit --skipLibCheck --project tsconfig.test.json && vitest run",
    "lint:obsidian": "eslint src/ tests/",
    "check": "npm test && npm run build && npm run lint:obsidian",
    "version": "node version-bump.mjs && git add manifest.json versions.json"
  },
  "devDependencies": {
    "@types/node": "^20.19.0",
    "@typescript-eslint/parser": "^8.61.1",
    "esbuild": "^0.28.0",
    "eslint": "^9.39.4",
    "eslint-plugin-obsidianmd": "^0.3.0",
    "obsidian": "1.13.1",
    "typescript": "^5.9.3",
    "vitest": "^3.2.6"
  }
}
